# ============================================================
#  Souf Web — Environment variables (example)
#  Copy this file to .env.local and fill in your values.
#  All NEXT_PUBLIC_* vars are exposed to the browser.
# ============================================================

# Public site URL (used for OpenGraph metadata, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://soufweb.site

# Contact info shown on the site
NEXT_PUBLIC_PHONE=212724016604
NEXT_PUBLIC_EMAIL=contact@soufweb.site
NEXT_PUBLIC_INSTAGRAM=https://www.instagram.com/soufweb_/
NEXT_PUBLIC_LINKEDIN=https://www.linkedin.com/in/souf-web-47079740a/

# Default WhatsApp pre-filled message (URL-encoded)
NEXT_PUBLIC_WA_MSG=Bonjour%2C%20je%20voudrais%20discuter%20d%27un%20projet%20web
